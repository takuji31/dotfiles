: "${XDG_CONFIG_HOME:=$HOME/.config}"
: "${XDG_DATA_HOME:=$HOME/.local/share}"
export XDG_CONFIG_HOME XDG_DATA_HOME

if command -v mise >/dev/null 2>&1; then
  eval "$(mise activate bash)"
fi

if command -v starship >/dev/null 2>&1; then
  eval "$(starship init bash)"
fi
if command -v fzf >/dev/null 2>&1; then
  eval "$(fzf --bash)"
fi
if command -v zoxide >/dev/null 2>&1; then
  eval "$(zoxide init bash)"
fi
if command -v navi >/dev/null 2>&1; then
  eval "$(navi widget bash)"
fi
if command -v atuin >/dev/null 2>&1; then
  eval "$(atuin init bash --disable-up-arrow)"
fi
if command -v git-spice >/dev/null 2>&1; then
  alias gs=git-spice
fi
if command -v zellij >/dev/null 2>&1; then
  alias zj="zellij"
  alias za="zellij attach"
  alias zl="zellij list-sessions"
  alias zk="zellij kill-session"
  alias zp="zellij --layout .zellij.kdl"
fi
if command -v claude >/dev/null 2>&1; then
  alias opusplan='claude --model opusplan --permission-mode plan'
  alias sonnet='claude --model sonnet --settings '"'"'{"advisorModel":"opus"}'"'"''
fi

{{ if eq .chezmoi.os "windows" -}}
if command -v git-wt >/dev/null 2>&1; then eval "$(command git-wt config shell init bash)"; fi
{{ else -}}
if command -v wt >/dev/null 2>&1; then eval "$(command wt config shell init bash)"; fi
{{ end -}}

[ -e "$HOME/.bashrc_local" ] && . "$HOME/.bashrc_local"
