[alias]
    ci = commit -v
    co = checkout
    delete-merged-branches = !git branch --merged | grep -v master | grep -v '^devel' | grep -v '^*' | xargs -I % git branch -d %
    di = diff
    graph = log --graph --date-order -C -M --pretty=format:'<%h> %ad [%cn] %Cgreen%d%Creset %s' --all --date=short
    logg = log --stat --pretty=format:'%Cblue%h %Cgreen%ar %Cred%an %Creset%s %Cred%d'
    new = whatchanged HEAD@{1}..HEAD --reverse --stat
    st = status
    todos = ! git grep TODO\\(`git rev-parse --abbrev-ref HEAD`\\)
[color]
    branch = auto
    diff = auto
    status = auto
    ui = true
[core]
    attributesfile = ~/.gitattributes
	editor = nvim
    excludesfile = ~/.gitignore
    pager = delta
    trustctime = false
[user]
	email = takuji31@gmail.com
	name = Takuji Nishibayashi
[ghq]
    root = ~/.homesick/repos
    root = ~/projects
[github]
    user = takuji31
[hub]
    protocol = https
[push]
	default = simple
[include]
    path = ~/.gitconfig.local
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[diff]
    tool = code
[difftool "code"]
    cmd = code --wait --diff $LOCAL $REMOTE
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true
    side-by-side = true
    line-numbers = true
    syntax-theme = Catppuccin Mocha
[merge]
	conflictStyle = diff3
[merge "mergiraf"]
	name = mergiraf
	driver = mergiraf merge --git %O %A %B -s %S -x %X -y %Y -p %P -l %L
[pull]
	ff = only
[user]
  signingkey = ~/.ssh/id_ed25519.pub
[gpg]
  format = ssh
[gpg "ssh"]
  allowedSignersFile = ~/.config/git/allowed_signers
[commit]
  gpgsign = true
{{ if eq .chezmoi.os "windows" }}
[user]
  signingkey = ~/.ssh/id_ed25519.pub
[tag]
  gpgsign = true
[gpg "ssh"]
  program = "C:/Windows/System32/OpenSSH/ssh-keygen.exe"
[core]
  sshCommand = C:/Windows/System32/OpenSSH/ssh.exe
{{ end -}}
{{ if eq .chezmoi.os "linux" }}
{{   if (.chezmoi.kernel.osrelease | lower | contains "microsoft") }}
[user]
  signingkey = ~/.ssh/id_ed25519.pub
{{   end }}
{{ end -}}
