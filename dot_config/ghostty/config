# Shell
command = /opt/homebrew/bin/fish --login --interactive

# Font
font-family = Firge35Nerd Console
font-size = 18

# Theme (system appearance auto switch)
theme = light:TokyoNight Day,dark:TokyoNight

# Scrollback
scrollback-limit = 50000

# Split panes
unfocused-split-opacity = 0.85

# Clipboard
copy-on-select = clipboard

# Cursor
cursor-style = block
cursor-style-blink = false

# Window
window-padding-x = 4
window-padding-y = 4

# Keyboard: treat Option as Alt so tmux/Zellij can receive Alt+key
# (otherwise Option+i/h produce ˆ/˙ instead of sending Alt modifier)
macos-option-as-alt = true